# ============================================================================
# QWEN TTS VOICE CLONING - EXECUTABLE CODE FOR GOOGLE COLAB
# ============================================================================

# ============================================================================
# BLOCK 1: INSTALL DEPENDENCIES
# ============================================================================
print("=" * 80)
print("BLOCK 1: INSTALLING DEPENDENCIES")
print("=" * 80)

import subprocess
import sys

packages_to_install = [
    'qwen-tts'          # Main Qwen Text-to-Speech library
    ,'soundfile'        # Audio file I/O library
    ,'transformers'     # Hugging Face transformers for model loading
    ,'accelerate'       # For faster model inference
    # 'flash-attn'        # CUDA-optimized attention mechanism for faster inference
]

print("\n📦 Installing required packages...\n")

for package in packages_to_install:
    print(f"   Installing {package}...")
    subprocess.run([sys.executable, '-m', 'pip', 'install', '-q', package], check=True)

print("\n✅ All dependencies installed successfully!\n")

# ============================================================================
# BLOCK 2: IMPORT ALL LIBRARIES
# ============================================================================
print("=" * 80)
print("BLOCK 2: IMPORTING LIBRARIES")
print("=" * 80)

import torch
import soundfile as sf
from qwen_tts import Qwen3TTSModel
from IPython.display import Javascript, Audio, display
from google.colab import output, files
from base64 import b64decode
import os

print("\n✅ All libraries imported successfully!\n")

# ============================================================================
# BLOCK 3: LOAD THE QWEN3 TTS MODEL
# Qwen/Qwen3-TTS-12Hz-0.6B-Base
# Qwen/Qwen3-TTS-12Hz-1.7B-Base
# ============================================================================
print("\n" + "=" * 80)
print("BLOCK 5: LOADING QWEN3 TTS MODEL")
print("=" * 80)

MODEL_ID = "Qwen/Qwen3-TTS-12Hz-1.7B-Base"

print(f"\n🤖 Loading model: {MODEL_ID}")
print("   Device: CUDA (GPU)")
print("   Data Type: bfloat16")
print("   This may take 1-2 minutes...\n")

# Load model
model = Qwen3TTSModel.from_pretrained(
    MODEL_ID,
    device_map="cuda",
    dtype=torch.bfloat16
)

print("✅ Model loaded successfully!\n")

# ============================================================================
# BLOCK 4: CONFIGURE RECORDING PARAMETERS
# ============================================================================
print("=" * 80)
print("BLOCK 3: CONFIGURE RECORDING PARAMETERS")
print("=" * 80)

RECORD_DURATION = 10
REFERENCE_VOICE_FILE = "reference_voice.wav"
OUTPUT_VOICE_FILE = "cloned_voice.wav"

print(f"\n📋 Recording Configuration:")
print(f"   - Duration: {RECORD_DURATION} seconds")
print(f"   - Reference voice file: {REFERENCE_VOICE_FILE}")
print(f"   - Output file: {OUTPUT_VOICE_FILE}\n")

# ============================================================================
# BLOCK 5: CONFIGURE VOICE CLONING PARAMETERS
# ============================================================================
print("=" * 80)
print("BLOCK 6: CONFIGURE VOICE CLONING PARAMETERS")
print("=" * 80)

# Reference text: The exact text spoken in the reference audio
reference_text = "Once upon a time, there was a little girl named claude who is a 99 years old girl living in sydney."

# Text to generate: The text to be spoken with cloned voice
generated_text = """
On moonlit night, a small cup filled with warm dreams floated gently across the garden! As I sat by the window, my hands shook lightly. Sun began to rise, but not yet completely bright - it was like when you hold something in one hand and wait for it to grow bigger, slowly, carefully. The moon became round as soon as the first light touched the garden. Now the sun was beginning to turn into warm, golden orange! As day approached, I wanted my cup, but I couldn't be sure if sleep was coming
"""

# Target language
# Options = Chinese / English
target_language = "Chinese"

print(f"\n📝 Voice Cloning Configuration:")
print(f"   - Reference text: {reference_text}")
print(f"   - Target language: {target_language}")
print(f"   - Text to generate: {len(generated_text)} characters\n")

# ============================================================================
# BLOCK 6: UPLOAD VOICE FILE
# ============================================================================
print("=" * 80)
print("BLOCK 4: UPLOAD VOICE FILE")
print("=" * 80)

print("\n📁 Please select your reference audio file (.wav, .mp3, etc.)\n")

# Open file picker
uploaded_files = files.upload()

if len(uploaded_files) > 0:
    original_filename = list(uploaded_files.keys())[0]
    os.rename(original_filename, REFERENCE_VOICE_FILE)
    print(f"✅ File saved as '{REFERENCE_VOICE_FILE}'\n")
    print("📻 Playing uploaded voice:")
    display(Audio(REFERENCE_VOICE_FILE))
else:
    print("❌ No file uploaded!")
    exit()

# ============================================================================
# BLOCK 7: GENERATE VOICE CLONE
# ============================================================================
print("=" * 80)
print("BLOCK 7: GENERATING VOICE CLONE")
print("=" * 80)

print(f"\n🎵 Generating voice clone...")
print(f"   Reference audio: {REFERENCE_VOICE_FILE}")
print(f"   Language: {target_language}")
print(f"   This may take 2-5 minutes...\n")

# Generate cloned voice
wavs, sr = model.generate_voice_clone(
    text=generated_text,
    language=target_language,
    ref_audio=REFERENCE_VOICE_FILE,
    ref_text=reference_text
)

print(f"✅ Voice cloning completed!")
print(f"   Sample rate: {sr} Hz")
print(f"   Audio shape: {wavs[0].shape}\n")

# ============================================================================
# BLOCK 8: SAVE THE CLONED VOICE
# ============================================================================
print("=" * 80)
print("BLOCK 8: SAVING THE CLONED VOICE")
print("=" * 80)

# Save audio file
sf.write(OUTPUT_VOICE_FILE, wavs[0], sr)

print(f"\n💾 Audio saved successfully!")
print(f"   Filename: {OUTPUT_VOICE_FILE}")
print(f"   Sample rate: {sr} Hz")
print(f"   Duration: {len(wavs[0]) / sr:.2f} seconds\n")

# ============================================================================
# BLOCK 9: PLAY THE CLONED VOICE
# ============================================================================
print("=" * 80)
print("BLOCK 9: PLAYING THE CLONED VOICE")
print("=" * 80)

print(f"\n📻 Playing generated cloned voice:\n")
display(Audio(OUTPUT_VOICE_FILE))

print("\n✅ VOICE CLONING COMPLETE!")
print(f"   Your cloned voice is saved as: {OUTPUT_VOICE_FILE}\n")

# ============================================================================
# BLOCK 10: DOWNLOAD THE AUDIO FILE
# This project leverages the Qwen 3 TTS model to generate synthetic speech by cloning a voice from a provided reference audio sample
# ============================================================================
print("=" * 80)
print("BLOCK 10: DOWNLOAD THE AUDIO FILE")
print("=" * 80)

print(f"\n📥 Downloading '{OUTPUT_VOICE_FILE}' to your computer...\n")

from google.colab import files as colab_files
try:
    colab_files.download(OUTPUT_VOICE_FILE)
    print("✅ Download started!\n")
except Exception as e:
    print(f"   If download doesn't work, go to: Files panel > {OUTPUT_VOICE_FILE}\n")

# ============================================================================
# END
# ============================================================================
print("=" * 80)
print("✅ ALL TASKS COMPLETED!")
print("=" * 80)
print(f"\nYour cloned voice file: {OUTPUT_VOICE_FILE}\n")
